# Where your Kizlo backend (the API handler) is reachable, including the mount path.
NEXT_PUBLIC_KIZLO_BACKEND_URL=

# Webhook signing key — must match the Site secret in the Kizlo WordPress settings.
KIZLO_SITE_SECRET=

# Your WordPress connection for server-side REST calls.
KIZLO_WORDPRESS_URL=
KIZLO_WORDPRESS_USERNAME=
KIZLO_WORDPRESS_APPLICATION_PASSWORD=

# Point the app at a local dev stack (managed by `kizlo dev`) instead of the keys above:
# KIZLO_TARGET=dev
