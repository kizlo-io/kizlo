{
	"name": "kizlo-turbo",
	"private": true,
	"description": "A headless WordPress framework for TypeScript — monorepo.",
	"license": "MIT",
	"author": "Kizlo",
	"homepage": "https://github.com/kizlo-io/kizlo#readme",
	"bugs": "https://github.com/kizlo-io/kizlo/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kizlo-io/kizlo.git"
	},
	"engines": {
		"node": ">=22.14.0",
		"pnpm": ">=9.6.0"
	},
	"packageManager": "pnpm@10.34.4",
	"scripts": {
		"build": "turbo run build",
		"kizlo": "node packages/kizlo/dist/cli/index.js",
		"dev": "turbo watch dev --continue",
		"kill": "taskkill /f /im node.exe",
		"clean": "git clean -xdf node_modules",
		"clean:workspaces": "turbo run clean",
		"lint:ws": "pnpm dlx sherif@latest --ignore-package @kizlo/plugin-kizlo --ignore-package @kizlo/plugin-cf7 --ignore-package @kizlo/plugin-woocommerce --ignore-package kizlo-nextjs-template",
		"lint:ws:fix": "pnpm dlx sherif@latest --ignore-package @kizlo/plugin-kizlo --ignore-package @kizlo/plugin-cf7 --ignore-package @kizlo/plugin-woocommerce --ignore-package kizlo-nextjs-template --fix",
		"plugin:build": "node scripts/build-plugin.mjs",
		"plugin:release": "node scripts/release.mjs",
		"postinstall": "pnpm lint:ws && node scripts/postinstall.mjs",
		"typecheck": "turbo run typecheck",
		"test": "turbo run test --filter \"./packages/*\"",
		"test:only": "turbo run test --filter",
		"test:watch": "vitest",
		"check": "biome check .",
		"check:fix": "biome check . --write",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.5",
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.31.0",
		"@kizlo/cf7": "workspace:*",
		"@kizlo/woocommerce": "workspace:*",
		"@types/bun": "^1.3.0",
		"husky": "^9.1.7",
		"kizlo": "workspace:*",
		"turbo": "^2.5.8",
		"typescript": "catalog:"
	}
}
