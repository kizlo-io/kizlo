# ---------------------------------------------------------------------------
# Kizlo environment
# Copy this file to `.env` and fill in the values. `.env` is git-ignored.
# ---------------------------------------------------------------------------

# Node environment: development | production | test
NODE_ENV=development

# Base URL the Kizlo server is reachable at (used by the browser client).
NEXT_PUBLIC_SERVER_BASE_URL=http://localhost:3000

# Secret used to sign/encrypt Kizlo cookies and tokens. Use a long random string.
SITE_SECRET=change-me-to-a-long-random-secret

# ---------------------------------------------------------------------------
# WordPress connection
# Generate an application password under Users → Profile in wp-admin.
# ---------------------------------------------------------------------------
WORDPRESS_URL=http://localhost:8080
WORDPRESS_USERNAME=admin
WORDPRESS_APPLICATION_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ---------------------------------------------------------------------------
# Upstash Redis (optional — rate limiting / caching)
# ---------------------------------------------------------------------------
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
