{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "./build.json",
	"compilerOptions": {
		/** Emit types for internal packages to speed up editor performance. */
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"noEmit": false,
		"outDir": "${configDir}/dist"
	},
	"exclude": ["eslint.config.ts"]
}
