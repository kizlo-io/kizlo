{
	"name": "kizlo/contact-form-7",
	"description": "Kizlo Contact Form 7",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"autoload": {
		"psr-4": {
			"Kizlo\\Cf7\\": "src/php/"
		}
	},
	"authors": [
		{
			"name": "IDJGILL",
			"email": "inderjeetgill.me@gmail.com"
		}
	],
	"require": {
		"php": ">=8.2",
		"yahnis-elsts/plugin-update-checker": "^5.7"
	},
	"require-dev": {
		"phpstan/phpstan": "^2.2",
		"szepeviktor/phpstan-wordpress": "^2.0",
		"automattic/jetpack-changelogger": "^6.0"
	},
	"scripts": {
		"phpstan": "phpstan analyse --memory-limit=1G",
		"changelog": "changelogger"
	},
	"extra": {
		"changelogger": {
			"changelog": "CHANGELOG.md",
			"changes-dir": "changelog",
			"versioning": "semver",
			"link-template": "https://github.com/kizlo-io/kizlo/compare/kizlo-cf7-v${old}...kizlo-cf7-v${new}",
			"types": {
				"added": "Added",
				"changed": "Changed",
				"deprecated": "Deprecated",
				"removed": "Removed",
				"fixed": "Fixed",
				"security": "Security"
			}
		}
	}
}
