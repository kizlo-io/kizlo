{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**",
			"!!**/tooling/typescript",
			"!!**/worker-configuration.d.ts",
			"!!**/generated",
			"!!**/.changeset",
			"!!**/drizzle",
			"!!**/apps",
			"!!**/projects",
			"!node_modules"
		]
	},
	"formatter": {
		"enabled": true,
		"lineWidth": 140,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"nursery": {
				"useSortedClasses": {
					"fix": "safe",
					"level": "on"
				}
			},
			"suspicious": {
				"noExplicitAny": "off"
			},
			"complexity": {
				"noImportantStyles": "off"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "asNeeded"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
