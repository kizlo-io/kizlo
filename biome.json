{
	"$schema": "https://biomejs.dev/schemas/2.5.5/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**",
			"!!**/tooling/typescript",
			"!!**/generated",
			"!!**/.changeset",
			"!!**/*.php",
			"!!**/src/php",
			"!!**/vendor",
			"!node_modules"
		]
	},
	"formatter": {
		"enabled": true,
		"lineWidth": 140,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"nursery": {
				"useSortedClasses": {
					"fix": "safe",
					"level": "on"
				}
			},
			"suspicious": {
				"noConsole": "off",
				"noExplicitAny": "off",
				"noEmptyInterface": "off"
			},
			"complexity": {
				"noImportantStyles": "off"
			},
			"a11y": {
				"useSemanticElements": "off",
				"useKeyWithClickEvents": "off"
			},
			"correctness": {
				"noUnusedFunctionParameters": "off"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "asNeeded"
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"overrides": [
		{
			"includes": ["plugins/**"],
			"linter": {
				"rules": {
					"a11y": {
						"useSemanticElements": "off",
						"useKeyWithClickEvents": "off"
					},
					"correctness": {
						"noUnusedFunctionParameters": "off"
					}
				}
			}
		},
		{
			"includes": ["scripts/**"],
			"linter": {
				"rules": {
					"suspicious": {
						"noUndeclaredEnvVars": "off"
					}
				}
			}
		}
	]
}
