{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"tasks": {
		"topo": {
			"dependsOn": ["^topo"]
		},
		"build": {
			"dependsOn": ["topo", "^build"],
			"env": [
				"KIZLO_SITE_SECRET",
				"KIZLO_WORDPRESS_URL",
				"KIZLO_WORDPRESS_USERNAME",
				"NEXT_PUBLIC_KIZLO_BACKEND_URL",
				"KIZLO_WORDPRESS_APPLICATION_PASSWORD",
				"REVALIDATE_SECRET",
				"GITHUB_TOKEN"
			],
			"outputs": [".cache/tsbuildinfo.json", "dist/**", "build/**", ".next/**", "!.next/cache/**"]
		},
		"dev": {
			"dependsOn": ["^build"],
			"cache": false,
			"persistent": true,
			"interactive": true
		},
		"typecheck": {
			"dependsOn": ["topo", "^build"],
			"outputs": []
		},
		"test": {
			"dependsOn": ["topo"],
			"outputs": [],
			"cache": false
		},
		"clean": {
			"cache": false
		},
		"//#clean": {
			"cache": false
		},
		"//#check": {},
		"//#check:fix": {
			"cache": false
		}
	},
	"concurrency": "20",
	"globalPassThroughEnv": ["NODE_ENV", "CI", "VERCEL", "VERCEL_ENV", "VERCEL_URL", "NEXT_RUNTIME", "npm_lifecycle_event"]
}
