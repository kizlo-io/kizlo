{
	"framework": "nextjs",
	"tokens": {
		"kizloDir": "src/lib/kizlo",
		"appDir": "src/app",
		"alias": "@"
	},
	"initFiles": [
		{ "role": "server-entry", "path": "src/lib/kizlo/server/index.ts" },
		{ "role": "client", "path": "src/lib/kizlo/client.ts" },
		{ "role": "api-route", "path": "src/app/api/kizlo/[[...rest]]/route.ts" },
		{ "role": "robots", "path": "src/app/robots.txt/route.ts" },
		{ "role": "sitemap", "path": "src/app/sitemaps/[sitemap]/route.ts" },
		{ "role": "sitemap-redirect", "path": "src/app/sitemap.xml/route.ts" },
		{ "role": "manifest", "path": "src/app/site.webmanifest/route.ts" }
	],
	"patches": [{ "label": "root layout", "path": "src/app/layout.tsx", "exports": ["generateMetadata", "generateViewport"] }]
}
