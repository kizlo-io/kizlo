# ---------------------------------------------------------------------------
# kizlo.io web app environment
# Copy this file to `.env` and fill in the values. `web/.env` is git-ignored.
# The web app is a live Kizlo server (see src/lib/kizlo/server), so it reads
# the same config a consumer project would. `next build` resolves these
# eagerly, so every value must be present (placeholders are fine for a build).
# ---------------------------------------------------------------------------

# Backend URL this Kizlo server is reachable at, including the API mount path.
NEXT_PUBLIC_KIZLO_BACKEND_URL=http://localhost:3000/api/kizlo

# Secret used to sign/verify Kizlo webhooks. Use a long random string.
KIZLO_SITE_SECRET=change-me-to-a-long-random-secret

# WordPress connection. Generate an application password under
# Users → Profile in wp-admin (or paste the values `kizlo dev up` prints).
KIZLO_WORDPRESS_URL=http://localhost:8080
KIZLO_WORDPRESS_USERNAME=admin
KIZLO_WORDPRESS_APPLICATION_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# Optional. The plugin update feed reads public GitHub Releases unauthenticated
# (60 req/hr). Set a token only to raise the limit to 5000/hr.
# GITHUB_TOKEN=