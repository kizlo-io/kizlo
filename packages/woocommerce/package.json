{
  "name": "@kizlo/woocommerce",
  "version": "1.0.0-alpha.2",
  "type": "module",
  "description": "WooCommerce extension for Kizlo.",
  "keywords": [
    "wordpress",
    "headless",
    "woocommerce",
    "ecommerce",
    "store-api",
    "kizlo"
  ],
  "license": "MIT",
  "author": "Kizlo",
  "homepage": "https://github.com/kizlo-io/kizlo/tree/main/packages/woocommerce#readme",
  "bugs": "https://github.com/kizlo-io/kizlo/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kizlo-io/kizlo.git",
    "directory": "packages/woocommerce"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@kizlo/shared": "1.0.0-alpha.8",
    "jose": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "kizlo": "^1.0.0-alpha.18"
  }
}