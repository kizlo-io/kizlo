{
	"name": "kizlo",
	"version": "0.3.2",
	"type": "module",
	"description": "A headless WordPress toolkit for TypeScript.",
	"keywords": [
		"wordpress",
		"headless",
		"headless-wordpress",
		"headless-cms",
		"wordpress-api",
		"rest-api",
		"typescript",
		"nextjs",
		"sdk"
	],
	"license": "MIT",
	"author": "Kizlo",
	"homepage": "https://github.com/kizlo-io/kizlo/tree/main/packages/kizlo#readme",
	"bugs": "https://github.com/kizlo-io/kizlo/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kizlo-io/kizlo.git",
		"directory": "packages/kizlo"
	},
	"engines": {
		"node": ">=22.14.0"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"kizlo": "./dist/cli/index.js"
	},
	"exports": {
		"./package.json": "./package.json",
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			}
		},
		"./config": {
			"import": {
				"types": "./dist/config.d.ts",
				"default": "./dist/config.js"
			}
		},
		"./test": {
			"import": {
				"types": "./dist/test.d.ts",
				"default": "./dist/test.js"
			}
		},
		"./nextjs": {
			"import": {
				"types": "./dist/nextjs.d.ts",
				"default": "./dist/nextjs.js"
			}
		},
		"./nextjs/server": {
			"import": {
				"types": "./dist/nextjs/server.d.ts",
				"default": "./dist/nextjs/server.js"
			}
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": [
		"./dist/cli/**"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown -w",
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"prepack": "bun ../../.github/replace-workspace-protocol.ts",
		"typecheck": "tsc --noEmit",
		"test": "vitest run --passWithNoTests"
	},
	"dependencies": {
		"@clack/prompts": "^1.5.1",
		"@kizlo/shared": "workspace:*",
		"@orpc/client": "^1.14.3",
		"@orpc/contract": "^1.14.3",
		"@orpc/openapi": "^1.14.3",
		"@orpc/openapi-client": "^1.14.3",
		"@orpc/server": "^1.14.3",
		"chokidar": "^5.0.0",
		"citty": "^0.1.6",
		"consola": "^3.2.3",
		"cookie": "^1.0.2",
		"jiti": "^2.7.0",
		"jose": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@tooling/typescript": "workspace:*",
		"@types/node": "catalog:",
		"@types/react": "catalog:react19",
		"@types/react-dom": "catalog:react19",
		"next": "catalog:",
		"react": "catalog:react19",
		"react-dom": "catalog:react19",
		"tsdown": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"peerDependencies": {
		"next": "^14.0.0 || ^15.0.0 || ^16.0.0",
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0"
	},
	"peerDependenciesMeta": {
		"next": {
			"optional": true
		},
		"react": {
			"optional": true
		},
		"react-dom": {
			"optional": true
		}
	}
}
